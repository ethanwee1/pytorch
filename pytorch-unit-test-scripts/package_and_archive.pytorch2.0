#!/bin/bash
set -e
set +x

# Determine target directory for upload
read -p "Enter name of uploader: " USERNAME
TARGET_DIR="$(date +%Y%m%d)_${USERNAME}"
TARGET_DIR="s3://mlse.frameworks/pytorch/unit_test_audit/pytorch2.0_bringup/${TARGET_DIR}"
echo "Will upload all files to ${TARGET_DIR}"

# Gather inputs to upload
# Words of the form $'string' are treated specially. The word expands to string, with backslash-escaped characters replaced as specified by the ANSI C standard. 
read -p $'Please provide the absolute path to the directory that you wish to upload. Please make sure that any files that you wish to upload eg. test reports, logs etc. are all included in the directory: \n' SOURCE_DIR
# TODO: check that path exists
if [ ! -d "${SOURCE_DIR}" ]; then
	echo "directory ${SOURCE_DIR} doesn't exist"
	exit 1
fi
echo "Please provide the following information to completely capture the environment used for generating these artifacts"
read -p "ROCm docker image tag: " ROCM_DOCKER
read -p "CUDA docker image tag (if applicable, otherwise leave blank): " CUDA_DOCKER
echo "Please provide any relevant additional info regarding what changes were made (if any) to the build/runtime environment to generate these artifacts. You can use markdown (.md) formatting. Multiple lines are OK. Hit 'Ctrl+D' at the end to terminate input."
readarray ADDITIONAL_INFO
# create README.md in tmp directory
README_PATH=/tmp/README.md
echo "ROCm docker: ${ROCM_DOCKER}" > ${README_PATH}
echo "CUDA docker: ${CUDA_DOCKER}" >> ${README_PATH}
echo "${ADDITIONAL_INFO[@]}" >> ${README_PATH}

# Tar file
TARFILE=files.tar.gz
echo "Creating ${TARFILE} from ${SOURCE_DIR}"
tar -cvzf ${TARFILE} ${SOURCE_DIR}

# Upload to AWS
export AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
export AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
pip3 --no-cache-dir install --upgrade awscli
# TODO: check if path exists and if so, append a number to end
if [[ $(aws --region=us-east-2 s3 ls --summarize ${TARGET_DIR}/ | grep "Total Objects:" | sed -E -e 's/.*Total Objects: ([0-9]+).*/\1/') -gt 0 ]]; then
	echo "WARNING: OBJECTS FOUND IN ${TARGET_DIR}! MIGHT BE OVERWRITING OBJECTS!"
        read -p "Do you wish to continue? y/n: " OVERWRITE
	[ ${OVERWRITE} == "y" ] || { echo "Aborting... please rerun the script and provide a different name eg. 'john_1'"; exit 1; }
fi
aws --region=us-east-2 s3 cp ${TARFILE} ${TARGET_DIR}/
aws --region=us-east-2 s3 cp ${README_PATH} ${TARGET_DIR}/

set +x
